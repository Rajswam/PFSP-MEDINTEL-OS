{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the PFSP-MEDINTEL OS.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Case": {
      "title": "Case",
      "description": "A medical case analysis.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique case ID" },
        "userId": { "type": "string", "description": "Owner UID" },
        "patientId": { "type": "string", "description": "Patient reference ID" },
        "date": { "type": "string", "description": "Date string" },
        "report": { "type": "string", "description": "Generated report markdown" },
        "chatHistory": { "type": "string", "description": "JSON stringified chat history" },
        "medicalCodes": { "type": "string", "description": "JSON stringified array of extracted medical codes" },
        "homeostasisData": { "type": "string", "description": "JSON stringified homeostasis assessment" },
        "pathophysiologyData": { "type": "string", "description": "JSON stringified pathophysiology assessment" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "userId", "patientId", "report", "createdAt"]
    },
    "KnowledgeBase": {
      "title": "KnowledgeBase",
      "description": "Represents a knowledge base document or article.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the document." },
        "userId": { "type": "string", "description": "The UID of the user who uploaded the document." },
        "title": { "type": "string", "description": "Title of the document." },
        "summary": { "type": "string", "description": "A brief summary of the document." },
        "content": { "type": "string", "description": "The extracted text content of the document." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["id", "userId", "title", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/cases/{caseId}": {
      "schema": { "$ref": "#/entities/Case" },
      "description": "Medical cases."
    },
    "/knowledgeBase/{kbId}": {
      "schema": { "$ref": "#/entities/KnowledgeBase" },
      "description": "Stores knowledge base documents."
    }
  }
}
